// Growth agent V1 — schema
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Config {
  id        String   @id @default(cuid())
  json      Json // { headline, sousTitre, ctaText, ctaColor (hex), heroVariant 'A'|'B'|'C' }
  active    Boolean  @default(false)
  createdBy String // 'agent' | 'human'
  parentId  String?
  createdAt DateTime @default(now())

  events    Event[]

  @@index([active])
  @@index([createdAt])
}

model Event {
  id        String   @id @default(cuid())
  configId  String
  config    Config   @relation(fields: [configId], references: [id], onDelete: Cascade)
  sessionId String
  type      String // 'view' | 'click_cta' | 'form_qualified'
  utmSource String?
  utmTerm   String?
  createdAt DateTime @default(now())

  @@index([configId])
  @@index([type])
  @@index([sessionId])
}

model Decision {
  id              String   @id @default(cuid())
  configIdFrom    String?
  configIdTo      String?
  hypothesis      String
  reasoning       String   @db.Text
  proximalDelta   Float?
  downstreamDelta Float?
  verdict         String // 'ship' | 'reject' | 'abstain'
  accelerated     Boolean  @default(false)
  createdAt       DateTime @default(now())

  @@index([createdAt])
}

// Single-row lock + mode flag to prevent concurrent agent steps
model AgentLock {
  id        Int      @id @default(1)
  running   Boolean  @default(false)
  mode      String   @default("accelerated") // 'live' | 'accelerated'
  updatedAt DateTime @updatedAt
}
